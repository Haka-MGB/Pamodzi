PAMODZI_SESSION_SECRET="replace-with-at-least-32-random-characters"

# Optional for local demos. Production should point at managed durable storage,
# or replace lib/server/db.ts with a real database adapter.
PAMODZI_DATA_FILE=".data/pamodzi-db.json"

# To generate a strong session secret locally:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

