PAMODZI_SESSION_SECRET="replace-with-at-least-32-random-characters"

# Optional for local demos. Production should point at managed durable storage,
# or replace lib/server/db.ts with a real database adapter.
PAMODZI_DATA_FILE=".data/pamodzi-db.json"

# Supabase Configuration
# Sign up at https://supabase.com and create a new project
# Get your Project URL and Anon Key from Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# To generate a strong session secret locally:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
